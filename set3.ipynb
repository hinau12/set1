   "source": [
    "dict1 = {'a': 10, 'b': 20, 'c': 30}\n",
    "dict2 = {'b': 15, 'c': 25, 'd': 40}\n",
    "\n",
    "merged = dict1.copy()\n",
    "\n",
    "for key, value in dict2.items():\n",
    "    if key in merged:\n",
    "        merged[key] += value\n",
    "    else:\n",
    "        merged[key] = value\n",
    "\n",
    "print(\"Merged Dictionary:\")\n",
    "print(merged)"
   ]
  }
 ],
